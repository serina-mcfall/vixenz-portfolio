---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';
import { readingTime } from '../../lib/reading-time';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.published.localeCompare(a.data.published)
);

const postsWithMeta = posts.map(post => ({
  ...post,
  readMinutes: readingTime(post.body ?? ''),
  topic: post.data.tags[0] ?? null,
}));
---
<Page title="Tech notes · Serina McFall" description="What I'm learning, what I tripped on, what I think about the tools I use.">
  <header class="opener">
    <p class="label">TECH NOTES</p>
    <h1>Tech notes</h1>
    <p class="lede">What I'm learning, what I tripped on, what I think about the tools I use.</p>
  </header>

  <ul class="posts">
    {postsWithMeta.map(post => (
      <li>
        <a href={`/blog/${post.id}`} class="card">
          {post.topic && <p class="topic">{post.topic}</p>}
          <h2 class="title">{post.data.title}</h2>
          <p class="summary">{post.data.summary}</p>
          <p class="meta">
            <time datetime={post.data.published}>{post.data.published}</time>
            <span> · </span>
            <span>{post.readMinutes} min read</span>
          </p>
        </a>
      </li>
    ))}
  </ul>
</Page>

<style>
  .label {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--mist);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    opacity: 0.75;
  }

  .opener h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 300;
    letter-spacing: -0.015em;
    margin-bottom: 1rem;
  }

  .lede {
    font-size: var(--text-lede);
    color: var(--mist);
    line-height: 1.65;
    margin-bottom: var(--space-section);
    max-width: 36rem;
  }

  .posts {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    gap: 1.25rem;
    padding: 0;
    margin: 0;
  }

  .card {
    display: block;
    background: var(--surface-card);
    backdrop-filter: blur(var(--surface-card-blur));
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    position: relative;
    z-index: var(--z-content);
    transition: transform 200ms ease, backdrop-filter 200ms ease, box-shadow 200ms ease;
  }

  .card:hover,
  .card:focus-visible {
    transform: translateY(-2px);
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 24px rgba(232, 180, 196, 0.12);
  }

  .card:focus-visible {
    outline: 2px solid var(--magnolia);
    outline-offset: 4px;
  }

  .topic {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--magnolia);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    opacity: 0.65;
  }

  .title {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--moonlight);
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }

  .summary {
    color: var(--mist);
    font-size: 0.9rem;
    line-height: 1.55;
    margin-bottom: 0.85rem;
    max-width: none;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--mist);
    letter-spacing: 0.06em;
    opacity: 0.75;
  }

  @media (prefers-reduced-motion: reduce) {
    .card {
      transition: none;
    }
    .card:hover,
    .card:focus-visible {
      transform: none;
    }
  }
</style>