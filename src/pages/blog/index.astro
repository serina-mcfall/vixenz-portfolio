---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.published.localeCompare(a.data.published)
);
---
<Page title="Blog — Serina McFall" description="Reflection writing on what I'm building and learning.">
  <header class="opener">
    <p class="label">BLOG</p>
    <h1>Writing</h1>
    <p class="lede">Reflection posts. Notes on what I am learning, what I tripped on, what I think.</p>
  </header>

  <ul class="posts">
    {posts.map(post => (
      <li>
        <a href={`/blog/${post.id}`}>
          <time datetime={post.data.published}>{post.data.published}</time>
          <h2>{post.data.title}</h2>
          <p>{post.data.summary}</p>
        </a>
      </li>
    ))}
  </ul>
</Page>

<style>

   .label {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--lotus);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .opener h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: 1rem;
  }

  .lede {
    font-size: var(--text-lede);
    color: var(--mist);
    line-height: 1.6;
    margin-bottom: 2.5rem;
    max-width: 36rem;
  }

  .posts {
    list-style-type: none;
    display: grid;
    gap: 1rem;

  }

  .posts a {
    display: block;
    background: var(--deep-sky);
    border: 1px solid var(--tile-border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 120ms ease, transform 120ms ease;

  }

  .posts a:hover, .posts a:focus-visible {
    border-color: var(--mist);
    transform: translateY(-2px);

  }

  .posts time {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--lotus);
    letter-spacing: 0.06em;
    display: block;
    margin-bottom: 0.5rem;
  }

  .posts h2 {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--moonlight);
    margin-bottom: 0.375rem;
    line-height: 1.3;

  }

  .posts p {
    color: var(--mist);
    font-size: 0.9rem;
    line-height: 1.55;
    max-width: none;

  }

</style>
