---
import Page from '../layouts/Page.astro'
import {site} from '../lib/site'
import CaseStudyTile from '../components/CaseStudyTile.astro'
import NowStrip from '../components/NowStrip.astro'

const tiles = [
  {
    href:'/work/atlas',
    ord: 'I',
    title:'Atlas - a Visual concept library',
    blurb: 'I took my bootcamp art-gallery, gave it a real purpose, and designed it accessibility-first from the brief.',
    featured: true, 
  },
  {
    href: '/work/moonlit-library',
    ord: 'II',
    title: 'Moonlit Library — three credentials, one shipped repo',
    blurb: 'A Dev Academy fullstack challenge that became three submitted assessments and a deployed product. Designed for how I read.',
  },
  {
    href: '/work/avalune-compendium',
    ord: 'III',
    title: 'Avalune Compendium - by hand',
    blurb: 'Express + Knex + SQLite, no ORM magic. Learning relational fundamentals by wiring them up',
  },
]

const nowItems = [
  {label:'building', text: 'Atlas — a visual concept library', href: '/work/atlas'},
  {label:'next', text: 'Dev Academy AI Launchpad · 27 Jul – 13 Nov 2026', href: '/about'},
  { label: 'open to', text: 'Auckland-based and remote work' },
];
---

<Page title={site.name} description={site.tagline}>

<section class='hero'>
  <h1>
    Serina McFall
    <span class="dot">.</span>
  </h1>
  <p class="tagline">
    {site.tagline}
  </p>
  <p class="meta">
  Auckland · Open to remote
</p>

</section>

<section aria-labelledby="work-heading" class="work">
  <h2 id="work-heading" class="sr-only">Case Studies</h2>
  <div class="grid">
    {tiles.map(t => <CaseStudyTile {...t}/>)}
  </div>
</section>

<NowStrip items={nowItems}/>

<section class="contact" aria-labelledby="contact-heading">
  <h2 id="contact-heading" class="contact-h">If we should talk —</h2>
  <p>
    Email <a href={`mailto:${site.email}`}>{site.email}</a> ·
    see <a href="/about">more about me</a> ·
    <a href="/cv">grab my CV</a>.
  </p>
</section>

</Page>

<style>
  .hero {
  margin-bottom: 3rem;
  animation: hero-fade-in var(--fade-in) ease-out both;
}

.hero h1 {
  margin-bottom: 1rem;
  font-weight: 300;
  letter-spacing: -0.015em;
}

.hero .dot {
  color: var(--magnolia);
  opacity: 0.65;
}

.tagline {
  font-size: var(--text-lede);
  color: var(--mist);
  max-width: 36rem;
  line-height: 1.65;
}

  .meta {
  font-family: var(--font-mono);
  font-size: var(--text-meta);
  color: var(--mist);
  letter-spacing: 0.14em;
  margin-top: 1.25rem;
  opacity: 0.75;
}
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

    .contact { margin-top: var(--space-section); }

  .contact-h {
    font-weight: 300;
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 1.25rem;
  }

  .contact p a {
    color: var(--moonlight);
    text-decoration: underline;
    text-decoration-color: rgba(232, 180, 196, 0.6);
    text-underline-offset: 3px;
    text-decoration-thickness: 1.5px;
    transition: text-decoration-color 150ms ease, text-shadow 200ms ease;
  }

  .contact p a:hover,
  .contact p a:focus-visible {
    text-decoration-color: var(--magnolia);
    text-shadow: 0 0 12px rgba(232, 180, 196, 0.35);
  }

  .contact p a:focus-visible {
    outline: 2px solid var(--magnolia);
    outline-offset: 3px;
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .contact p a {
      transition: none;
    }
  }

  @keyframes hero-fade-in {
    from { opacity: 0;}
    to { opacity: 1;}
  }

  @media (prefers-reduced-motion: reduce) {
    .hero {
      animation: none;
    }
  }
</style>















