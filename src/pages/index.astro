---
import Page from '../layouts/Page.astro'
import {site} from '../lib/site'
import CaseStudyTile from '../components/CaseStudyTile.astro'
import NowStrip from '../components/NowStrip.astro'

const tiles = [
  {
    href:'/work/atlas',
    ord: 'I',
    title:'Atlas - a Visual concept library',
    blurb: 'I took my bootcamp art-gallery, gave it a real purpose, and designed it accessibility-first from the brief.',
    featured: true, 
  },
  {
    href: '/work/mtg-project',
    ord: 'II',
    title: 'The MTG Project — planning a system',
    blurb: 'Eight design docs for a Commander deck-builder I have not built yet. How I plan a non-trivial system.',
  },
  {
    href: '/work/avalune-compendium',
    ord: 'III',
    title: 'Avalune Compendium - by hand',
    blurb: 'Express + Knex + SQLite, no ORM magic. Learning relational fundamentals by wiring them up',
  },
]

const nowItems = [
  {label:'building', text: 'Avalune- a Next.js worldbuilding site', href: '/now'},
  {label:'next', text: 'The Learning Companion Project', href: '/lab'},
  { label: 'open to', text: 'Auckland-based and remote work  · Summer of Tech 2026/27' },
];
---

<Page title={site.name} description={site.tagline}>

<section class='hero'>
  <h1>
    Serina McFall
    <span class="dot">.</span>
  </h1>
  <p class="tagline">
    {site.tagline}
  </p>
  <p class="meta">
     — Auckland · open to remote · Summer of Tech 2026/27
  </p>

</section>

<section aria-labelledby="work-heading" class="work">
  <h2 id="work-heading" class="sr-only">Case Studies</h2>
  <div class="grid">
    {tiles.map(t => <CaseStudyTile {...t}/>)}
  </div>
</section>

<NowStrip items={nowItems}/>

<section class="contact" aria-labelledby="contact-heading">
  <h2 id="contact-heading" class="contact-h">If we should talk —</h2>
  <p>
    Email <a href={`mailto:${site.email}`}>{site.email}</a> ·
    see <a href="/about">more about me</a> ·
    <a href="/cv">grab my CV</a>.
  </p>
</section>

</Page>

<style>
  .hero { margin-bottom: 3rem; }
  .hero h1 { margin-bottom: 1rem; }
  .hero .dot { color: var(--magnolia); }

  .tagline {
    font-size: var(--text-lede);
    color: var(--mist);
    max-width: 36rem;
    line-height: 1.55;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--lotus);
    letter-spacing: 0.04em;
    margin-top: 1.25rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  .contact { margin-top: 3rem; }

  .contact-h {
    font-size: var(--text-h3);
    margin-bottom: 0.75rem;
  }
</style>















