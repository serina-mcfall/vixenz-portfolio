---

import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro'

const entries = await getCollection('lab');
const sorted = entries.sort((a, b) => 
(b.data.started || '').localeCompare(a.data.started || ''))

---

<Page title='Lab — Serina McFall' description='Side projects, sketches, and ideas in progress'>
  <header class="opener">
  <p class="label">LAB</p>
  <h1>Side projects and ideas-in-progress</h1>
  <p class="lede">Half-finished things, future-vision sketches, experiments. Allowed to be unpolished.</p>
</header>

  <ul class="entries">
    {sorted.map (e => (
      <li>
        <a href={`/lab/${e.id}`}>
          <span class="status">{e.data.status}</span>
          <h2>{e.data.title}</h2>
          <p>{e.data.summary}</p>
        </a>
      </li>
     ))}

    
  </ul>
</Page>

<style>

  .label {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--lotus);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .opener h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: 1rem;
  }

  .lede {
    font-size: var(--text-lede);
    color: var(--mist);
    line-height: 1.6;
    margin-bottom: 2.5rem;
    max-width: 36rem;
  }

  .entries {
    list-style-type: none;
    display: grid;
    gap: 1rem;

  }
  
  .entries a {
  display: block;
  background: var(--deep-sky);
  border: 1px solid var(--tile-border);
  border-radius: 10px;
  padding: 1.25rem 1.5rem;
  text-decoration: none;
  color: inherit;
  transition: border-color 120ms ease, transform 120ms ease;
  }

  .entries a:hover,
  .entries a:focus-visible {
  border-color: var(--mist);
  transform: translateY(-2px);
  }

  .entries .status{
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--lotus);
    letter-spacing: 0.06rem;
    text-transform: uppercase;
    margin-bottom: 0.5rem;

  }

  .entries h2 {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--moonlight);
    margin-bottom: 0.375rem;
    line-height: 1.3;

  }

  .entries p {
    color: var(--mist);
    font-size: 0.9rem;
    line-height: 1.55;
    max-width: none;
  }

</style>