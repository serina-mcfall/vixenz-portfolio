---
import { getCollection, render } from 'astro:content';
import Page from '../../layouts/Page.astro';

export async function getStaticPaths() {
  const entries = await getCollection('work');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Page title={entry.data.title} description={entry.data.summary}>
  <article class="case-study">
    <header>
      <p class="label">
        CASE STUDY · {entry.data.ord}{entry.data.status === 'draft' ? ' · DRAFT' : ''}
      </p>
      <h1>{entry.data.title}</h1>
      <p class="lede">{entry.data.summary}</p>
      <ul class="links">
        {entry.data.repo && <li><a href={entry.data.repo}>repo</a></li>}
        {entry.data.live && <li><a href={entry.data.live}>live</a></li>}
      </ul>
    </header>
    <div class="body">
      <Content />
    </div>
  </article>
</Page>

<style>

  .label {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--lotus);
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
  }

  .case-study h1 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: 1rem;
  }

  .lede {
    font-size: var(--text-lede);
    color: var(--mist);
    line-height: 1.6;
    margin-bottom: 2.5rem;
    max-width: 36rem;
  }

  .links {
    list-style: none;
    display: flex;
    gap: 1.25rem;
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    margin-bottom: 2.5rem;

  }

  .body :global(h2) {
    margin-top: 2.5rem;
    color: var(--lantern);
    
  }

  .body :global(ol) {
  padding-left: 1.5rem;
  margin: 1rem 0;
}
</style>
