---
interface Props {
  href:string;
  ord: string;
  title: string;
  blurb: string;
  featured?: boolean; 
}

const { href, ord, title, blurb, featured = false } = Astro.props;

---

<a href={href} class:list={['tile', { featured }]}>
<span class="ord">{ord} · Case study</span>
<h2 class ="title">{title}</h2>
<p class="blurb">{blurb}</p>
</a>

<style>
  .tile {
    display: block;
    background: var(--surface-card);
    backdrop-filter: blur(var(--surface-card-blur));
    border-radius: 10px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    position: relative;
    z-index: var(--z-content);
    transition: transform 200ms ease, backdrop-filter 200ms ease, box-shadow 200ms ease;
  }

  .tile.featured {
    box-shadow: inset 0 0 0 1px rgba(232, 180, 196, 0.35);
  }

  .tile:hover,
  .tile:focus-visible {
    transform: translateY(-2px);
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 24px rgba(232, 180, 196, 0.12);
  }

  .tile.featured:hover,
  .tile.featured:focus-visible {
    box-shadow:
      inset 0 0 0 1px rgba(232, 180, 196, 0.5),
      0 8px 24px rgba(232, 180, 196, 0.18);
  }

  .tile:focus-visible {
    outline: 2px solid var(--magnolia);
    outline-offset: 4px;
  }

  .ord {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--mist);
    letter-spacing: 0.14em;
    margin-bottom: 0.625rem;
    opacity: 0.75;
  }

  .title {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--moonlight);
    margin-bottom: 0.375rem;
    line-height: 1.3;
  }

  .blurb {
    color: var(--mist);
    font-size: 0.85rem;
    line-height: 1.55;
    max-width: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .tile {
      transition: none;
    }
    .tile:hover,
    .tile:focus-visible {
      transform: none;
    }
  }
</style>