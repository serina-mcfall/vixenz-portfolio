---
interface Props {
  href:string;
  ord: string;
  title: string;
  blurb: string;
  featured?: boolean; 
}

const { href, ord, title, blurb, featured = false } = Astro.props;

---

<a href={href} class:list={['tile', { featured }]}>
<span class="ord">CASE STUDY · {ord} </span>
<h2 class ="title">{title}</h2>
<p class="blurb">{blurb}</p>
</a>

<style>
  .tile {
    display: block;                         
    background: var(--deep-sky);
    border: 1px solid var(--tile-border);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    color: inherit;
    border-bottom: 1px solid var(--tile-border);  
    transition: border-color 120ms ease, transform 120ms ease;
  }

  .tile:hover,
  .tile:focus-visible {
    border-color: var(--mist);
    transform: translateY(-2px);
  }

  .tile.featured {
    border-left: 3px solid var(--magnolia);
  }

  .ord {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--lotus);
    letter-spacing: 0.06em;
    margin-bottom: 0.625rem;
  }

  .title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--moonlight);
    margin-bottom: 0.375rem;
    line-height: 1.3;
  }

  .blurb {
    color: var(--mist);
    font-size: 0.85rem;
    line-height: 1.55;
    max-width: none;                        
  }

  
  .tile.featured .ord {
    color: var(--magnolia);
  }
</style>