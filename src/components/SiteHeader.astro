---
import { site, nav } from '../lib/site';

const path = Astro.url.pathname;
---
<header>
  <div class="bar">
    <a href="/" class="brand">{site.brand}</a>
    <nav aria-label="Primary">
      <ul>
        {nav.map(item => {
          const current =
            path === item.href ||
            (item.href.length > 1 && path.startsWith(item.href));
          return (
            <li>
              <a
                href={item.href}
                aria-current={current ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  
  header {
    padding: 1.5rem var(--gutter) 2rem;
    border-bottom: 1px solid var(--tile-border);
    background: rgba(22, 21, 46, 0.75);
    backdrop-filter: blur(6px);
    position: relative;
    z-index: var(--z-content);
  }

  .bar {
    max-width: var(--content-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .brand {
    font-family: var(--font-mono);
    color: var(--lantern);
    font-weight: 500;
    font-size: var(--text-ui);
    letter-spacing: 0.04em;
    text-decoration: none;
    border: none;
    margin-right: auto;
  }
  .brand:hover,
  .brand:focus-visible {
    color: var(--moonlight);
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  nav a {
    font-family: var(--font-mono);
    font-size: var(--text-ui);
    color: var(--mist);
    text-decoration: none;
    border: none;
    letter-spacing: 0.04em;
    padding: 2px 6px;
    border-radius: 4px;
    transition: color 150ms ease, box-shadow 200ms ease;
  }

  nav a[aria-current='page'] {
    color: var(--moonlight);
    border-bottom: 1px solid var(--magnolia);
    box-shadow: 0 0 12px rgba(232, 180, 196, 0.15);
  }

  nav a:hover,
  nav a:focus-visible {
    color: var(--moonlight);
    box-shadow: 0 0 16px rgba(232, 180, 196, 0.35);
  }

  nav a:focus-visible {
    outline: 2px solid var(--magnolia);
    outline-offset: 4px;
  }

  @media (prefers-reduced-motion: reduce) {
    nav a {
      transition: none;
    }
  }

</style>
