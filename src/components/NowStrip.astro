---
interface Item {
  label: string;
  text: string;
  href?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;

---

<section aria-labelledby="now-heading" class="strip">
  <h2 id="now-heading" class="heading">Currently</h2>
  <ul>
    {items.map(item => (
      <li>
        <span class="label">{item.label}</span>
        <span class="text">
          {item.href ? <a href={item.href}>{item.text}</a> : item.text}
        </span>
      </li>
    ))}
  </ul>
</section>

<style>
.strip {
  background: var(--surface-card);
  backdrop-filter: blur(var(--surface-card-blur));
  border-radius: 10px;
  padding: clamp(1.25rem, 3vw, 2rem);
  margin: var(--space-section) 0;
  position: relative;
  z-index: var(--z-content);
}

  .heading {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--mist);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  ul {
    list-style: none;
    display: grid;
    gap: 0.5rem;
  }

  li {
    display: flex;
    gap: 1.5rem;
    align-items: baseline;
  }

  .label {
    font-family: var(--font-mono);
    font-size: var(--text-meta);
    color: var(--mist);
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 7rem;
    opacity: 0.75;
  }

  .text {
    color: var(--moonlight);
  }

  .text a {
    color: var(--moonlight);
    text-decoration: underline;
    text-decoration-color: rgba(232, 180, 196, 0.6);
    text-underline-offset: 3px;
    text-decoration-thickness: 1.5px;
    transition: text-decoration-color 150ms ease, text-shadow 200ms ease;
  }

  .text a:hover,
  .text a:focus-visible {
    text-decoration-color: var(--magnolia);
    text-shadow: 0 0 12px rgba(232, 180, 196, 0.35);
  }

  .text a:focus-visible {
    outline: 2px solid var(--magnolia);
    outline-offset: 3px;
    border-radius: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    .text a {
      transition: none;
    }
  }
</style>